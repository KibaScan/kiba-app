# Kiba — example environment variables
#
# Copy this file to .env and fill in the values. .env is gitignored and
# must never be committed. The EXPO_PUBLIC_* keys are bundled into the
# mobile app binary, so only put values you are comfortable shipping
# publicly. Server-side keys (without the EXPO_PUBLIC_ prefix) are used
# by scripts/ and Supabase Edge Functions and are never bundled.

# Supabase project — https://app.supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Server-side (scripts + Edge Functions only; never in app binary)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Claude Haiku — https://console.anthropic.com (used by ingredient parsing)
ANTHROPIC_API_KEY=<sk-ant-...>

# Scrape.do — https://scrape.do (used by the import pipeline)
SCRAPEDO_API_KEY=<scrapedo-api-key>

# RevenueCat — https://www.revenuecat.com (paywall SDK)
REVENUECAT_API_KEY=<revenuecat-api-key>
EXPO_PUBLIC_REVENUECAT_API_KEY=<revenuecat-api-key>
